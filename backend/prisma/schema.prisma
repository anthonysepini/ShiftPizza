generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
//  url      = env("postgresql://neondb_owner:npg_I6PBlEZajSy1@ep-noisy-fire-acewqhel.sa-east-1.aws.neon.tech/neondb?sslmode=require")
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  ADMIN
  EMPLOYEE
}

enum ScheduleStatus {
  SCHEDULED
  ABSENT
  EXTRA_SHIFT
  DAY_OFF
  REMOVED_SHIFT
}

enum ScheduleSource {
  AUTO
  MANUAL
}

// ─── Tabelas ─────────────────────────────────────────────

model Employee {
  id        String   @id @default(cuid())
  fullName  String
  cpf       String   @unique
  phone     String?
  position  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User?
  weeklyRules  WeeklyScheduleRule[]
  scheduleDays ScheduleDay[]

  @@map("employees")
}

model User {
  id           String   @id @default(cuid())
  employeeId   String   @unique
  passwordHash String
  role         Role     @default(EMPLOYEE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee    Employee      @relation(fields: [employeeId], references: [id])
  auditLogs   AuditLog[]
  changedDays ScheduleDay[] @relation("ChangedBy")

  @@map("users")
}

model WeeklyScheduleRule {
  id         String  @id @default(cuid())
  employeeId String
  weekday    Int     // 0=Dom  1=Seg  2=Ter  3=Qua  4=Qui  5=Sex  6=Sab
  shouldWork Boolean @default(true)

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, weekday])
  @@map("weekly_schedule_rules")
}

model ScheduleDay {
  id              String         @id @default(cuid())
  employeeId      String
  date            DateTime       @db.Date
  status          ScheduleStatus @default(SCHEDULED)
  source          ScheduleSource @default(AUTO)
  note            String?
  changedByUserId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  employee  Employee @relation(fields: [employeeId], references: [id])
  changedBy User?    @relation("ChangedBy", fields: [changedByUserId], references: [id])

  @@unique([employeeId, date])
  @@map("schedule_days")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  entity      String
  entityId    String
  metadata    Json?
  createdAt   DateTime @default(now())

  actor User @relation(fields: [actorUserId], references: [id])

  @@map("audit_logs")
}