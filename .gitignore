
## .gitignore

```gitignore
# dependências
node_modules/
frontend/node_modules/
backend/node_modules/

# build
dist/
frontend/dist/
backend/dist/
coverage/
*.tsbuildinfo

# variáveis de ambiente
.env
.env.*
!.env.example
frontend/.env
frontend/.env.*
frontend/.env.local
frontend/.env.development.local
frontend/.env.production.local
backend/.env
backend/.env.*
backend/.env.local

# logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# editor / IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj*
*.sln
*.sw?

# sistema operacional
.DS_Store
Thumbs.db

# arquivos locais de deploy
.vercel/

# cache / temporários
.cache/
.temp/
tmp/

# arquivos gerados
generated/prisma/
backend/generated/prisma/
